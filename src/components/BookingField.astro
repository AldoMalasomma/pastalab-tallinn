---
interface Props {
  label: string;
  name: string;
  type?: "text" | "email" | "date" | "time" | "number" | "tel" | "textarea";
  help?: string;
  placeholder?: string;
  required?: boolean;
  min?: string | number;
  max?: string | number;
  step?: string | number;
  autocomplete?: string;
  rows?: number;
}

const {
  label,
  name,
  type = "text",
  help,
  placeholder,
  required = true,
  min,
  max,
  step,
  autocomplete,
  rows = 4,
} = Astro.props as Props;

const id = `booking-${name}`;
const describedBy = help ? `${id}-help` : undefined;
const baseClasses =
  "w-full rounded-2xl border border-ink/10 bg-cream/35 px-4 py-3 text-base text-ink outline-none transition placeholder:text-smoke/70 focus:border-copper focus:bg-white focus:ring-4 focus:ring-copper/10";
---

<div class="space-y-2">
  <label for={id} class="text-sm font-medium text-ink">
    <span>{label}</span>
  </label>

  {
    type === "textarea" ? (
      <textarea
        id={id}
        name={name}
        rows={rows}
        placeholder={placeholder}
        required={required}
        aria-describedby={describedBy}
        class={`${baseClasses} min-h-32 resize-y`}
      ></textarea>
    ) : (
      <input
        id={id}
        name={name}
        type={type}
        placeholder={placeholder}
        required={required}
        min={min}
        max={max}
        step={step}
        inputmode={type === "number" ? "numeric" : type === "tel" ? "tel" : undefined}
        autocomplete={autocomplete}
        aria-describedby={describedBy}
        class={baseClasses}
      />
    )
  }

  {help ? (
    <p id={describedBy} class="text-sm leading-6 text-smoke">
      {help}
    </p>
  ) : null}
</div>
