---
import {
  imageryDirection,
  getResponsiveImage,
  type ImagerySlot,
} from "../data/imagery";

interface Props {
  slot: ImagerySlot;
  class?: string;
  src?: string;
  alt?: string;
  caption?: string;
  loading?: "eager" | "lazy";
  sizes?: string;
}

const {
  slot,
  class: className = "",
  src,
  alt,
  caption,
  loading = "lazy",
  sizes,
} = Astro.props as Props;
const visual = imageryDirection[slot];
const responsive = getResponsiveImage(slot);
const assetSrc = src ?? visual.src;
const assetAlt = alt ?? visual.alt;
const assetCaption = caption ?? visual.caption;
const assetSizes = sizes ?? responsive.sizes;
const ratioClass =
  visual.ratio === "portrait"
    ? "aspect-[4/5]"
    : visual.ratio === "wide"
      ? "aspect-[3/2]"
    : visual.ratio === "square"
      ? "aspect-square"
      : "aspect-[16/10]";
const surfaceClass =
  visual.theme === "dark"
    ? "bg-[linear-gradient(160deg,rgba(29,29,27,1),rgba(52,46,39,1))] text-white"
    : "bg-[linear-gradient(160deg,rgba(255,255,255,0.94),rgba(245,239,230,0.96))] text-ink";
const borderClass = visual.theme === "dark" ? "border-white/10" : "border-ink/10";
const accentClass =
  visual.theme === "dark" ? "bg-copper/25" : "bg-copper/18";
const labelClass = visual.theme === "dark" ? "text-white/55" : "text-smoke";
const copyClass = visual.theme === "dark" ? "text-white/75" : "text-smoke";
---

<figure
  class={`overflow-hidden rounded-[2rem] border shadow-[0_28px_70px_-45px_rgba(29,29,27,0.45)] ${borderClass} ${surfaceClass} ${className}`}
>
  <div class={`relative ${ratioClass} p-5 md:p-6`}>
    <div aria-hidden="true" class="absolute inset-0">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(164,90,42,0.24),transparent_40%),radial-gradient(circle_at_bottom_left,rgba(90,104,70,0.16),transparent_30%)]"></div>
      <div class={`absolute right-0 top-0 h-40 w-40 translate-x-1/3 -translate-y-1/3 rounded-full blur-3xl ${accentClass}`}></div>
      <div class={`absolute left-0 bottom-0 h-56 w-56 -translate-x-1/3 translate-y-1/3 rounded-full blur-3xl ${accentClass}`}></div>
      <div class="absolute inset-5 rounded-[1.5rem] border border-current/10"></div>
      <div class="absolute left-6 top-6 h-px w-24 bg-current/10"></div>
      <div class="absolute bottom-6 right-6 h-px w-24 bg-current/10"></div>
    </div>

    <div class="relative flex h-full flex-col justify-between">
      <div class="relative flex-1 overflow-hidden rounded-[1.5rem] border border-current/10">
        {assetSrc ? (
          <>
            <picture>
              <source type="image/webp" srcset={responsive.webpSrcSet} sizes={assetSizes} />
              <img
                src={assetSrc}
                alt={assetAlt}
                loading={loading}
                decoding="async"
                fetchpriority={loading === "eager" ? "high" : "auto"}
                sizes={assetSizes}
                class="absolute inset-0 h-full w-full object-cover"
              />
            </picture>
          </>
        ) : null}

        <div class={`absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(164,90,42,0.22),transparent_40%),radial-gradient(circle_at_bottom_left,rgba(90,104,70,0.16),transparent_30%)] ${assetSrc ? "opacity-100" : "opacity-100"}`}></div>
        <div class={`absolute inset-0 ${assetSrc ? "bg-[linear-gradient(180deg,rgba(0,0,0,0.05),rgba(0,0,0,0.28))]" : "bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.12))]"}`}></div>

        {!assetSrc ? (
          <div class="relative flex h-full flex-col justify-between p-5 md:p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class={`text-[11px] uppercase tracking-[0.24em] ${labelClass}`}>
                  {visual.label}
                </p>
                <p class="mt-3 max-w-xs text-2xl font-semibold leading-tight tracking-[-0.03em]">
                  {visual.title}
                </p>
              </div>
              <span class={`rounded-full border border-current/10 px-3 py-1 text-[11px] uppercase tracking-[0.22em] ${labelClass}`}>
                {visual.crop}
              </span>
            </div>

            <div class="mt-8 space-y-4">
              <p class={`max-w-md text-sm leading-7 ${copyClass}`}>
                {visual.description}
              </p>

              <div class="flex flex-wrap gap-2">
                {visual.notes.map((note) => (
                  <span class={`rounded-full border border-current/10 px-3 py-1 text-[11px] uppercase tracking-[0.2em] ${labelClass}`}>
                    {note}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <div class="relative flex h-full flex-col justify-between p-5 md:p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class={`text-[11px] uppercase tracking-[0.24em] ${labelClass}`}>
                  {visual.label}
                </p>
                <p class="mt-3 max-w-xs text-2xl font-semibold leading-tight tracking-[-0.03em]">
                  {visual.title}
                </p>
              </div>
              <span class={`rounded-full border border-current/10 px-3 py-1 text-[11px] uppercase tracking-[0.22em] ${labelClass}`}>
                {visual.crop}
              </span>
            </div>

            <div class="mt-8 flex items-end justify-between gap-4">
              <p class={`max-w-sm text-sm leading-7 ${copyClass}`}>
                {assetCaption}
              </p>
              <span class={`rounded-full border border-current/10 px-3 py-1 text-[11px] uppercase tracking-[0.2em] ${labelClass}`}>
                {visual.notes[0]}
              </span>
            </div>
          </div>
        )}
      </div>

      <div class={`flex items-center gap-3 pt-4 ${labelClass}`}>
        <span class="h-px flex-1 bg-current/12"></span>
        <span class="text-[11px] uppercase tracking-[0.22em]">Visual slot</span>
        <span class="h-px flex-1 bg-current/12"></span>
      </div>
    </div>
  </div>
</figure>
