---
import BrandMark from "./BrandMark.astro";
import {
  getCurrentSlugFromUrl,
  getLangFromUrl,
  getLocalizedPath,
  languages,
  type Locale,
  useTranslations,
} from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentSlug = getCurrentSlugFromUrl(Astro.url);
const localeBasePath = getLocalizedPath(lang);
const headerLabel = t("header", "navigation");

function localizedPath(targetLang: Locale) {
  return getLocalizedPath(targetLang, currentSlug);
}

const navItems = [
  { slug: "", href: localeBasePath, label: t("nav", "home") },
  { slug: "house", href: getLocalizedPath(lang, "house"), label: t("nav", "house") },
  { slug: "menu", href: getLocalizedPath(lang, "menu"), label: t("nav", "menu") },
  { slug: "booking", href: getLocalizedPath(lang, "booking"), label: t("nav", "booking") },
] as const;

const mobileMenuId = "mobile-navigation";
---

<header class="border-b border-ink/10 bg-white/80 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 sm:px-6 lg:gap-8 lg:px-8 lg:py-4">
    <BrandMark
      href={localeBasePath}
      imageClass="w-[10.75rem] max-w-[58vw] sm:w-[12.5rem] sm:max-w-[52vw] lg:w-[15.5rem] lg:max-w-[72vw]"
      class="shrink-0"
      variant="primary"
    />

    <nav class="ml-auto hidden items-center gap-6 whitespace-nowrap lg:flex">
      {
        navItems.map((item) => {
          const isActive = currentSlug === item.slug;

          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "text-sm transition",
                isActive ? "text-copper font-medium" : "text-ink/75 hover:text-copper",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="hidden shrink-0 items-center gap-2 lg:flex">
      {
        Object.entries(languages).map(([code, label]) => (
          <a
            href={localizedPath(code)}
            class:list={[
              "rounded-lg px-2 py-1 text-xs transition",
              code === lang
                ? "bg-copper text-white"
                : "bg-black/5 text-ink hover:bg-black/10",
            ]}
          >
            {label}
          </a>
        ))
      }
    </div>

    <button
      type="button"
      aria-controls={mobileMenuId}
      aria-expanded="false"
      data-menu-open
      class="ml-auto inline-flex items-center gap-3 rounded-full border border-ink/10 bg-white/90 px-4 py-2 text-sm font-medium text-ink shadow-sm transition hover:bg-white lg:hidden"
    >
      <span class="flex h-8 w-8 items-center justify-center rounded-full border border-ink/10 bg-cream/80">
        <span class="relative block h-3.5 w-4">
          <span class="absolute inset-x-0 top-0 h-px bg-ink"></span>
          <span class="absolute inset-x-0 top-1.5 h-px bg-ink"></span>
          <span class="absolute inset-x-0 bottom-0 h-px bg-ink"></span>
        </span>
      </span>
      <span>{t("header", "openMenu")}</span>
    </button>
  </div>

  <dialog
    id={mobileMenuId}
    data-menu-dialog
    class="m-0 h-[100dvh] w-screen max-w-none border-0 bg-transparent p-0"
  >
    <div class="flex min-h-full flex-col overflow-y-auto bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(245,239,230,0.98))] px-5 pb-6 pt-5 sm:px-6">
      <div class="flex items-start justify-between gap-4">
        <BrandMark
          href={localeBasePath}
          imageClass="w-[11.25rem] max-w-[62vw]"
          variant="primary"
        />

        <button
          type="button"
          data-menu-close
          class="inline-flex items-center gap-2 rounded-full border border-ink/10 bg-white/90 px-4 py-2 text-sm font-medium text-ink shadow-sm transition hover:bg-white"
        >
          <span class="text-base leading-none">×</span>
          <span>{t("header", "closeMenu")}</span>
        </button>
      </div>

      <div class="mt-8 border-t border-ink/10 pt-5">
        <p class="text-[11px] uppercase tracking-[0.26em] text-copper">
          {headerLabel}
        </p>
        <nav class="mt-4 space-y-3">
          {
            navItems.map((item, index) => {
              const isActive = currentSlug === item.slug;

              return (
                <a
                  href={item.href}
                  aria-current={isActive ? "page" : undefined}
                  class:list={[
                    "flex items-center justify-between rounded-[1.5rem] border px-5 py-4 transition",
                    isActive
                      ? "border-copper/30 bg-white text-copper shadow-sm"
                      : "border-ink/10 bg-white/80 text-ink hover:border-copper/20 hover:bg-white",
                  ]}
                  data-menu-link
                >
                  <span class="flex items-center gap-4">
                    <span class="text-[11px] uppercase tracking-[0.24em] text-smoke">
                      0{index + 1}
                    </span>
                    <span class="text-lg font-medium tracking-[-0.02em]">
                      {item.label}
                    </span>
                  </span>
                  <span class="text-[11px] uppercase tracking-[0.24em] text-smoke">
                    {item.slug || t("nav", "home")}
                  </span>
                </a>
              );
            })
          }
        </nav>
      </div>

      <div class="mt-8 border-t border-ink/10 pt-5">
        <p class="text-[11px] uppercase tracking-[0.26em] text-copper">
          {t("header", "language")}
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            Object.entries(languages).map(([code, label]) => (
              <a
                href={localizedPath(code)}
                class:list={[
                  "rounded-full px-4 py-2 text-xs transition",
                  code === lang
                    ? "bg-copper text-white"
                    : "bg-black/5 text-ink hover:bg-black/10",
                ]}
                data-menu-link
              >
                {label}
              </a>
            ))
          }
        </div>
      </div>

      <div class="mt-auto pt-8">
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href={getLocalizedPath(lang, "booking")}
            class="inline-flex flex-1 items-center justify-center rounded-full bg-copper px-6 py-3.5 text-sm font-medium text-white transition hover:opacity-90"
            data-menu-link
          >
            {t("nav", "booking")}
          </a>
          <a
            href={getLocalizedPath(lang, "menu")}
            class="inline-flex flex-1 items-center justify-center rounded-full border border-ink/10 bg-white px-6 py-3.5 text-sm font-medium text-ink transition hover:bg-black/5"
            data-menu-link
          >
            {t("nav", "menu")}
          </a>
        </div>
      </div>
    </div>
  </dialog>

  <script type="module">
    const menuDialog = document.querySelector("[data-menu-dialog]");
    const menuOpenButton = document.querySelector("[data-menu-open]");
    const menuCloseButtons = document.querySelectorAll("[data-menu-close]");
    const menuLinks = document.querySelectorAll("[data-menu-link]");

    const setMenuState = (isOpen) => {
      if (menuOpenButton instanceof HTMLButtonElement) {
        menuOpenButton.setAttribute("aria-expanded", String(isOpen));
      }

      document.documentElement.classList.toggle("overflow-hidden", isOpen);
    };

    const closeMenu = () => {
      if (menuDialog instanceof HTMLDialogElement && menuDialog.open) {
        menuDialog.close();
      }

      setMenuState(false);
    };

    if (
      menuDialog instanceof HTMLDialogElement &&
      menuOpenButton instanceof HTMLButtonElement
    ) {
      menuOpenButton.addEventListener("click", () => {
        if (!menuDialog.open) {
          menuDialog.showModal();
        }

        setMenuState(true);
      });

      menuDialog.addEventListener("close", () => {
        setMenuState(false);
      });

      menuDialog.addEventListener("cancel", (event) => {
        event.preventDefault();
        closeMenu();
      });

      menuDialog.addEventListener("click", (event) => {
        if (event.target === menuDialog) {
          closeMenu();
        }
      });
    }

    menuCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        closeMenu();
      });
    });

    menuLinks.forEach((link) => {
      link.addEventListener("click", () => {
        closeMenu();
      });
    });
  </script>

  <style is:global>
    [data-menu-dialog]::backdrop {
      background: rgba(245, 239, 230, 0.72);
      backdrop-filter: blur(12px);
    }
  </style>
</header>
