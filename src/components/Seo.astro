---
import { imageryDirection } from "../data/imagery";
import { defaultLang, getLocalizedPath, languages, type Locale } from "../i18n/ui";

interface Props {
  title: string;
  description: string;
  lang: Locale;
  path?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const {
  title,
  description,
  lang,
  path = "",
  canonicalUrl,
  noindex = false,
  ogImage = imageryDirection.socialPreview.src ?? "/assets/images/pasta-lab-og-default.png",
  ogImageAlt = imageryDirection.socialPreview.alt,
  ogImageWidth = 1200,
  ogImageHeight = 630,
} = Astro.props as Props;

const localeCodes: Record<Locale, string> = {
  it: "it_IT",
  en: "en_US",
  et: "et_EE",
  ru: "ru_RU",
};

const localeList = Object.keys(languages) as Locale[];
const currentPath = canonicalUrl ?? getLocalizedPath(lang, path);
const canonical = new URL(currentPath, Astro.url).toString();
const alternateLocales = localeList.filter((locale) => locale !== lang);
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
<link rel="canonical" href={canonical} />

{
  !noindex && (
    <>
      {localeList.map((locale) => (
        <link
          rel="alternate"
          hreflang={locale}
          href={new URL(getLocalizedPath(locale, path), Astro.url).toString()}
        />
      ))}
      <link
        rel="alternate"
        hreflang="x-default"
        href={new URL(getLocalizedPath(defaultLang, path), Astro.url).toString()}
      />
    </>
  )
}

<meta property="og:site_name" content="Pasta Lab & Smoked Flavors" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={localeCodes[lang]} />
<meta property="og:image" content={new URL(ogImage, Astro.url).toString()} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />

{
  !noindex && alternateLocales.map((locale) => (
    <meta property="og:locale:alternate" content={localeCodes[locale]} />
  ))
}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, Astro.url).toString()} />
<meta name="twitter:image:alt" content={ogImageAlt} />
