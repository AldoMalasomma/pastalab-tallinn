---
import EditorialVisual from "./EditorialVisual.astro";
import type { HomeContent } from "../data/home";
import { houseContent } from "../data/house";
import { getResponsiveImage } from "../data/imagery";
import { getLocalizedPath, type Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
  content: HomeContent;
}

const { lang, content } = Astro.props as Props;
const house = houseContent[lang];
const homeHero = getResponsiveImage("homeHero");
---

<main class="relative isolate overflow-hidden">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
  >
    <div
      class="absolute inset-x-0 top-0 h-[32rem] bg-[radial-gradient(circle_at_top,rgba(164,90,42,0.16),transparent_55%),linear-gradient(180deg,rgba(255,255,255,0.8),rgba(245,239,230,0))]"
    >
    </div>
    <div
      class="absolute left-1/2 top-16 h-72 w-72 -translate-x-1/2 rounded-full bg-copper/10 blur-3xl"
    ></div>
    <div
      class="absolute right-0 top-56 h-80 w-80 translate-x-1/3 rounded-full bg-olive/10 blur-3xl"
    ></div>
  </div>

  <section class="mx-auto max-w-[88rem] px-4 pb-12 pt-8 sm:px-6 lg:px-8 lg:pb-16 lg:pt-10">
    <div class="relative overflow-hidden rounded-[2.5rem] border border-ink/10 bg-ink shadow-[0_36px_100px_-60px_rgba(29,29,27,0.85)]">
      <div aria-hidden="true" class="absolute inset-0">
        <picture>
          <source type="image/webp" srcset={homeHero.webpSrcSet} sizes={homeHero.sizes} />
          <img
            src={homeHero.fallback}
            alt=""
            loading="eager"
            decoding="async"
            fetchpriority="high"
            sizes={homeHero.sizes}
            class="absolute inset-0 h-full w-full object-cover object-[72%_50%] sm:object-[66%_50%] lg:object-[60%_48%]"
          />
        </picture>
        <div class="absolute inset-0 bg-[linear-gradient(110deg,rgba(13,13,12,0.82)_0%,rgba(13,13,12,0.58)_34%,rgba(13,13,12,0.22)_62%,rgba(13,13,12,0.45)_100%),radial-gradient(circle_at_top_right,rgba(164,90,42,0.22),transparent_32%),radial-gradient(circle_at_bottom_left,rgba(90,104,70,0.18),transparent_28%)]"></div>
        <div class="absolute inset-x-0 bottom-0 h-28 bg-[linear-gradient(180deg,transparent,rgba(13,13,12,0.62))]"></div>
      </div>

      <div class="relative min-h-[calc(100svh-8.5rem)] lg:min-h-[46rem]">
        <div class="flex min-h-[inherit] items-end lg:items-center">
          <div class="grid w-full gap-8 px-5 py-8 sm:px-8 sm:py-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(18rem,0.64fr)] lg:gap-10 lg:px-10 lg:py-12 xl:px-12">
            <div class="max-w-3xl text-white">
              <p class="inline-flex rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs uppercase tracking-[0.24em] text-copper/80 shadow-sm backdrop-blur-sm">
                {content.hero.eyebrow}
              </p>

              <h1 class="mt-6 max-w-3xl text-3xl font-semibold leading-[0.92] tracking-[-0.04em] text-white drop-shadow-[0_10px_30px_rgba(0,0,0,0.35)] sm:text-4xl lg:text-5xl xl:text-[5.25rem]">
                {content.hero.title}
              </h1>

              <p class="mt-6 max-w-xl text-base leading-7 text-white/80 sm:max-w-2xl sm:text-lg sm:leading-8">
                {content.hero.subtitle}
              </p>

              <div class="mt-8 flex flex-wrap gap-3 sm:gap-4">
                <a
                  href={getLocalizedPath(lang, "booking")}
                  class="inline-flex items-center rounded-full bg-copper px-6 py-3.5 text-sm font-medium text-white shadow-[0_14px_30px_-16px_rgba(164,90,42,0.85)] transition hover:opacity-90"
                >
                  {content.hero.primaryCta}
                </a>
                <a
                  href={getLocalizedPath(lang, "menu")}
                  class="inline-flex items-center rounded-full border border-white/15 bg-white/10 px-6 py-3.5 text-sm font-medium text-white transition hover:bg-white/15"
                >
                  {content.hero.secondaryCta}
                </a>
              </div>

              <div class="mt-8 grid gap-3 sm:mt-10 sm:grid-cols-2">
                {
                  content.hero.meta.map((item) => (
                    <div class="rounded-2xl border border-white/10 bg-white/10 p-3.5 text-white shadow-sm backdrop-blur-sm">
                      <p class="text-[11px] uppercase tracking-[0.24em] text-white/55">
                        {item.label}
                      </p>
                      <p class="mt-2 text-sm font-medium leading-6 text-white/85">
                        {item.value}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="max-w-sm border-t border-white/10 pt-6 text-white/80 lg:justify-self-end lg:self-end lg:border-l lg:border-t-0 lg:border-white/15 lg:pl-6 lg:pt-0">
              <p class="text-[11px] uppercase tracking-[0.24em] text-copper/90">
                {content.hero.panel.eyebrow}
              </p>
              <h2 class="mt-4 text-xl font-semibold leading-tight text-white sm:text-2xl">
                {content.hero.panel.title}
              </h2>
              <p class="mt-4 text-sm leading-7 text-white/75">
                {content.hero.panel.text}
              </p>

              <div class="mt-5 space-y-3">
                {content.hero.panel.points.map((point) => (
                  <div class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-copper"></span>
                    <p class="text-sm leading-6 text-white/80">{point}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-copper">
          {content.story.eyebrow}
        </p>
        <h2 class="mt-4 max-w-xl text-3xl font-semibold tracking-[-0.03em] text-ink sm:text-4xl lg:text-5xl">
          {content.story.title}
        </h2>
      </div>

      <div>
        <p class="max-w-3xl text-lg leading-8 text-smoke">{content.story.text}</p>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {content.story.highlights.map((highlight) => (
            <article class="rounded-[1.5rem] border border-ink/10 bg-white p-5 shadow-sm">
              <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-ink">
                {highlight.title}
              </h3>
              <p class="mt-3 text-sm leading-7 text-smoke">{highlight.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
    <div class="rounded-[2.25rem] border border-ink/10 bg-white p-6 shadow-sm sm:p-7 md:p-8 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
        <div>
          <p class="text-xs uppercase tracking-[0.24em] text-copper">
            {content.house.eyebrow}
          </p>
          <h2 class="mt-4 max-w-xl text-3xl font-semibold tracking-[-0.03em] text-ink sm:text-4xl lg:text-5xl">
            {content.house.title}
          </h2>
          <p class="mt-5 max-w-xl text-base leading-7 text-smoke">
            {content.house.text}
          </p>
          <p class="mt-6 text-xs uppercase tracking-[0.22em] text-copper">
            {house.story.pullQuoteLabel}
          </p>
          <p class="mt-3 max-w-xl text-lg leading-8 text-ink">
            {house.story.pullQuote}
          </p>
        </div>

        <div class="grid gap-4">
          <EditorialVisual slot="houseBridge" />

          <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
            {house.founders.members.map((member) => (
              <article class="rounded-[1.5rem] border border-ink/10 bg-cream/40 p-5">
                <p class="text-[11px] uppercase tracking-[0.24em] text-smoke">
                  {member.role}
                </p>
                <h3 class="mt-3 text-xl font-semibold text-ink">{member.name}</h3>
              </article>
            ))}
          </div>

          <div class="rounded-[1.5rem] border border-ink/10 bg-[linear-gradient(135deg,rgba(245,239,230,0.95),rgba(255,255,255,1))] p-5">
            <p class="text-xs uppercase tracking-[0.24em] text-copper">
              {content.house.note}
            </p>
            <a
              href={getLocalizedPath(lang, "house")}
              class="mt-4 inline-flex items-center rounded-full bg-copper px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
            >
              {content.house.button}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs uppercase tracking-[0.24em] text-copper">
          {content.dishes.eyebrow}
        </p>
        <h2 class="mt-4 max-w-xl text-3xl font-semibold tracking-[-0.03em] text-ink sm:text-4xl lg:text-5xl">
          {content.dishes.title}
        </h2>
      </div>

      <p class="max-w-2xl text-base leading-7 text-smoke">
        {content.dishes.intro}
      </p>
    </div>

    <div class="mt-8 grid gap-5 lg:mt-10 lg:grid-cols-3">
      {content.dishes.items.map((dish, index) => (
        <article class="group rounded-[2rem] border border-ink/10 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-[0_28px_70px_-50px_rgba(29,29,27,0.55)] sm:p-7">
          <div class="flex items-center justify-between">
            <span class="text-xs uppercase tracking-[0.24em] text-copper">
              0{index + 1}
            </span>
            <span class="h-2.5 w-2.5 rounded-full bg-copper/60"></span>
          </div>

          <h3 class="mt-5 text-2xl font-semibold leading-tight text-ink">
            {dish.name}
          </h3>

          <p class="mt-4 text-sm leading-7 text-smoke">{dish.description}</p>

          <div class="mt-6 border-t border-ink/10 pt-5 text-sm font-medium text-olive">
            {dish.note}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="overflow-hidden rounded-[2.5rem] bg-ink text-white shadow-[0_30px_90px_-45px_rgba(29,29,27,0.7)]">
      <div class="grid lg:grid-cols-[1.05fr_0.95fr]">
        <div class="p-7 md:p-10 lg:p-12">
          <p class="text-xs uppercase tracking-[0.24em] text-copper/80">
            {content.atmosphere.eyebrow}
          </p>
          <h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-[-0.03em] sm:text-4xl lg:text-5xl">
            {content.atmosphere.title}
          </h2>
          <p class="mt-6 max-w-2xl text-base leading-8 text-white/75">
            {content.atmosphere.text}
          </p>

          <div class="mt-8 rounded-[1.75rem] border border-white/10 bg-white/5 p-5 backdrop-blur">
            <p class="text-xs uppercase tracking-[0.24em] text-white/55">
              {content.atmosphere.note}
            </p>
            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              {content.atmosphere.features.map((feature) => (
                <article class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4">
                  <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-white">
                    {feature.title}
                  </h3>
                  <p class="mt-3 text-sm leading-7 text-white/70">
                    {feature.text}
                  </p>
                </article>
              ))}
            </div>
          </div>
        </div>

        <div class="border-t border-white/10 bg-[radial-gradient(circle_at_top_right,rgba(164,90,42,0.26),transparent_45%)] p-7 md:p-10 lg:border-l lg:border-t-0 lg:p-12">
          <p class="text-xs uppercase tracking-[0.24em] text-white/55">
            {content.cta.eyebrow}
          </p>
          <p class="mt-4 text-2xl font-medium leading-tight text-white">
            {content.cta.title}
          </p>

          <p class="mt-5 text-sm leading-7 text-white/75">{content.cta.text}</p>

          <ul class="mt-8 space-y-4">
            {content.cta.points.map((point) => (
              <li class="flex gap-3 rounded-[1.35rem] border border-white/10 bg-white/5 p-4">
                <span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-copper"></span>
                <div>
                  <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white">
                    {point.title}
                  </p>
                  <p class="mt-2 text-sm leading-7 text-white/70">
                    {point.text}
                  </p>
                </div>
              </li>
            ))}
          </ul>

          <p class="mt-6 text-sm leading-7 text-white/70">{content.cta.note}</p>

          <a
            href={getLocalizedPath(lang, "booking")}
            class="mt-8 inline-flex items-center rounded-full bg-copper px-6 py-3.5 text-sm font-medium text-white transition hover:opacity-90"
          >
            {content.cta.button}
          </a>
        </div>
      </div>
    </div>
  </section>
</main>
