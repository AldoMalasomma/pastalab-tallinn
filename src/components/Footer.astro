---
import BrandMark from "./BrandMark.astro";
import { getLocalizedPath, type Locale } from "../i18n/ui";
import { creatorBridge, footerDisclosureByLocale, legalLinks } from "../data/compliance";
import { hospitalityContent } from "../data/hospitality";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const content = hospitalityContent[lang];
const disclosure = footerDisclosureByLocale[lang];

const localizedLink = (slug: string) => getLocalizedPath(lang, slug);
---

<footer class="mt-16 border-t border-ink/10 bg-white/75 backdrop-blur">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8 lg:py-14">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="max-w-2xl">
        <BrandMark
          href={getLocalizedPath(lang)}
          imageClass="w-[18.5rem] sm:w-[20rem] max-w-[78vw]"
          class="mb-5"
          variant="signature"
        />
        <p class="text-xs uppercase tracking-[0.24em] text-copper">{content.eyebrow}</p>
        <h2 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-ink sm:text-3xl">
          {content.title}
        </h2>
        <p class="mt-4 max-w-xl text-sm leading-7 text-smoke">{content.text}</p>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div>
            <p class="text-[11px] uppercase tracking-[0.22em] text-copper">{content.addressLabel}</p>
            <p class="mt-2 text-sm leading-7 text-ink">{content.address}</p>
          </div>
          <div>
            <p class="text-[11px] uppercase tracking-[0.22em] text-copper">{content.hoursLabel}</p>
            <ul class="mt-2 space-y-1 text-sm leading-7 text-ink">
              {content.hours.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div>
            <p class="text-[11px] uppercase tracking-[0.22em] text-copper">{content.phoneLabel}</p>
            <a class="mt-2 block text-sm leading-7 text-ink transition hover:text-copper" href={`tel:${content.phone.replace(/\s+/g, "")}`}>
              {content.phone}
            </a>
          </div>
          <div>
            <p class="text-[11px] uppercase tracking-[0.22em] text-copper">{content.emailLabel}</p>
            <a class="mt-2 block text-sm leading-7 text-ink transition hover:text-copper" href={`mailto:${content.email}`}>
              {content.email}
            </a>
          </div>
        </div>
      </div>

      <div class="rounded-[2rem] border border-ink/10 bg-cream/45 p-6 shadow-sm md:p-7">
        <p class="text-[11px] uppercase tracking-[0.22em] text-copper">{content.reservationNoteLabel}</p>
        <p class="mt-3 text-sm leading-7 text-smoke">{content.reservationNote}</p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={localizedLink("booking")}
            class="inline-flex items-center rounded-full bg-copper px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
          >
            {content.bookingCtaLabel}
          </a>
          <a
            href={localizedLink("menu")}
            class="inline-flex items-center rounded-full border border-ink/10 bg-white px-5 py-3 text-sm font-medium text-ink transition hover:bg-black/5"
          >
            {content.menuCtaLabel}
          </a>
        </div>

        <div class="mt-8">
          <p class="text-[11px] uppercase tracking-[0.22em] text-copper">{content.linksLabel}</p>
          <div class="mt-3 flex flex-wrap gap-3">
            {content.links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                class="rounded-full border border-ink/10 bg-white px-4 py-2 text-sm text-ink transition hover:bg-black/5"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        <div class="mt-8 border-t border-ink/10 pt-5">
          <p class="text-[11px] uppercase tracking-[0.22em] text-copper">{disclosure.label}</p>
          <p class="mt-2 text-xs leading-6 text-smoke">{disclosure.text}</p>

          <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-xs leading-5 text-ink/75">
            <span class="uppercase tracking-[0.18em] text-copper">{creatorBridge.label}</span>
            <a
              href={creatorBridge.href}
              class="transition hover:text-copper"
            >
              {creatorBridge.name}
            </a>
            <span class="text-ink/25">•</span>
            <a
              href={creatorBridge.href}
              class="transition hover:text-copper"
            >
              {creatorBridge.email}
            </a>
          </div>

          <nav aria-label="Legal" class="mt-5 flex flex-wrap gap-x-4 gap-y-2">
            {legalLinks.map((link) => (
              <a
                href={link.href}
                class="text-xs text-ink/70 transition hover:text-copper"
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>
      </div>
    </div>
  </div>
</footer>
