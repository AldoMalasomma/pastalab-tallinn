---
type BrandVariant = "primary" | "signature" | "monogram";

interface Props {
  variant?: BrandVariant;
  class?: string;
}

const { variant = "primary", class: className = "" } = Astro.props as Props;

const serifStack = '"Iowan Old Style", "Palatino Linotype", Palatino, "Book Antiqua", Georgia, serif';
const sansStack = 'Inter, system-ui, sans-serif';
---

{
  variant === "primary" ? (
    <svg
      aria-hidden="true"
      class={`block h-auto ${className}`}
      focusable="false"
      viewBox="0 0 920 270"
      xmlns="http://www.w3.org/2000/svg"
    >
      <g fill="currentColor">
        <text
          x="0"
          y="118"
          font-family={serifStack}
          font-size="105"
          font-weight="700"
          letter-spacing="0.01em"
        >
          Pasta Lab
        </text>
        <text
          x="0"
          y="186"
          font-family={serifStack}
          font-size="61"
          font-style="italic"
          font-weight="600"
          letter-spacing="0.12em"
        >
          &amp; Smoked Flavors
        </text>
      </g>
    </svg>
  ) : variant === "signature" ? (
    <svg
      aria-hidden="true"
      class={`block h-auto ${className}`}
      focusable="false"
      viewBox="0 0 980 250"
      xmlns="http://www.w3.org/2000/svg"
    >
      <g fill="currentColor">
        <line x1="170" x2="810" y1="34" y2="34" stroke="currentColor" stroke-opacity=".18" />
        <text
          x="490"
          y="116"
          text-anchor="middle"
          font-family={serifStack}
          font-size="60"
          font-style="italic"
          font-weight="600"
          letter-spacing="0.01em"
        >
          Pasta Lab &amp; Smoked Flavors
        </text>
        <text
          x="490"
          y="166"
          text-anchor="middle"
          font-family={sansStack}
          font-size="18"
          font-weight="600"
          letter-spacing="0.28em"
        >
          ITALIAN CRAFT · BALTIC CHARACTER
        </text>
        <line x1="170" x2="810" y1="196" y2="196" stroke="currentColor" stroke-opacity=".12" />
      </g>
    </svg>
  ) : (
    <svg
      aria-hidden="true"
      class={`block h-auto ${className}`}
      focusable="false"
      viewBox="0 0 128 128"
      xmlns="http://www.w3.org/2000/svg"
    >
      <rect x="12" y="12" width="104" height="104" rx="28" fill="#171614" />
      <rect x="20" y="20" width="88" height="88" rx="22" fill="none" stroke="#f5efe6" stroke-opacity=".16" />
      <text
        x="64"
        y="78"
        text-anchor="middle"
        font-family={serifStack}
        font-size="50"
        font-weight="700"
        fill="#f5efe6"
        letter-spacing="0.02em"
      >
        PL
      </text>
      <line x1="41" x2="87" y1="89" y2="89" stroke="#a45a2a" stroke-linecap="round" stroke-width="3" />
    </svg>
  )
}
