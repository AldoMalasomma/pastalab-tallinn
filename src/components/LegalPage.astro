---
import Layout from "../layouts/Layout.astro";
import { creatorBridge, legalPageContent, type LegalPageKey } from "../data/compliance";

interface Props {
  page: LegalPageKey;
}

const pagePaths: Record<LegalPageKey, string> = {
  privacy: "privacy-policy",
  cookie: "cookie-policy",
  accessibility: "accessibility-statement",
  terms: "terms-of-use",
  colophon: "colophon",
};

const { page } = Astro.props as Props;
const content = legalPageContent[page];
const path = pagePaths[page];
---

<Layout
  title={content.pageTitle}
  description={content.description}
  lang="en"
  path={path}
  noindex={true}
>
  <main class="mx-auto max-w-4xl px-6 py-14 sm:py-16 lg:px-8 lg:py-20">
    <article class="rounded-[2rem] border border-ink/10 bg-white/85 px-6 py-8 shadow-sm sm:px-8 sm:py-10">
      <p class="text-[11px] uppercase tracking-[0.26em] text-copper">{content.eyebrow}</p>
      <h1 class="mt-4 text-3xl font-semibold tracking-[-0.04em] text-ink sm:text-4xl">
        {content.title}
      </h1>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-smoke sm:text-base">
        {content.intro}
      </p>

      <div class="mt-10 space-y-8">
        {content.sections.map((section) => (
          <section class="border-t border-ink/10 pt-6">
            <h2 class="text-sm font-medium tracking-[-0.02em] text-ink">
              {section.title}
            </h2>
            <div class="mt-3 space-y-3">
              {section.body.map((paragraph) => (
                <p class="text-sm leading-7 text-smoke">
                  {paragraph}
                </p>
              ))}
            </div>
          </section>
        ))}
      </div>

      <div class="mt-10 border-t border-ink/10 pt-6">
        {content.note && (
          <p class="text-sm leading-7 text-smoke">
            {content.note}
          </p>
        )}

        {page === "colophon" && (
          <div class="mt-5 rounded-[1.5rem] border border-ink/10 bg-cream/50 px-4 py-4">
            <p class="text-[11px] uppercase tracking-[0.24em] text-copper">
              Creator contact
            </p>
            <div class="mt-2 flex flex-col gap-1 text-sm leading-6 text-ink sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-3">
              <span class="font-medium">{creatorBridge.name}</span>
              <span class="hidden text-ink/25 sm:inline">•</span>
              <a class="transition hover:text-copper" href={creatorBridge.href}>
                {creatorBridge.email}
              </a>
            </div>
          </div>
        )}
      </div>
    </article>
  </main>
</Layout>
