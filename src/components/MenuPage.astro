---
import EditorialVisual from "./EditorialVisual.astro";
import type { MenuContent } from "../data/menu";
import { getLocalizedPath, type Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
  content: MenuContent;
}

const { lang, content } = Astro.props as Props;
---

<main class="relative isolate overflow-hidden">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-x-0 top-0 h-[24rem] bg-[radial-gradient(circle_at_top,rgba(164,90,42,0.15),transparent_55%),linear-gradient(180deg,rgba(255,255,255,0.8),rgba(245,239,230,0))]"></div>
    <div class="absolute left-1/2 top-12 h-64 w-64 -translate-x-1/2 rounded-full bg-copper/10 blur-3xl"></div>
  </div>

  <section class="mx-auto max-w-[88rem] px-4 pb-12 pt-12 sm:px-6 lg:px-8 lg:pb-16 lg:pt-20">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <div class="max-w-2xl">
        <p class="inline-flex rounded-full border border-copper/20 bg-white/80 px-4 py-2 text-xs uppercase tracking-[0.24em] text-copper shadow-sm backdrop-blur">
          {content.hero.eyebrow}
        </p>
        <h1 class="mt-6 text-4xl font-semibold leading-[0.94] tracking-[-0.04em] text-ink sm:text-5xl lg:text-7xl">
          {content.hero.title}
        </h1>
      </div>

      <p class="max-w-2xl text-base leading-7 text-smoke sm:text-lg sm:leading-8">
        {content.hero.subtitle}
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-copper">
          {content.structure.eyebrow}
        </p>
        <h2 class="mt-4 max-w-xl text-3xl font-semibold tracking-[-0.03em] text-ink sm:text-4xl lg:text-5xl">
          {content.structure.title}
        </h2>
        <p class="mt-5 max-w-xl text-base leading-7 text-smoke">
          {content.structure.text}
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {content.structure.cards.map((card) => (
          <article class="rounded-[1.75rem] border border-ink/10 bg-white p-6 shadow-sm">
            <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-ink">
              {card.title}
            </h3>
            <p class="mt-4 text-sm leading-7 text-smoke">{card.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-4 sm:px-6 lg:px-8 lg:py-4">
    <EditorialVisual slot="menuBanner" />
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="rounded-[2.5rem] border border-ink/10 bg-white p-6 shadow-sm sm:p-7 md:p-8 lg:p-10">
      <p class="text-xs uppercase tracking-[0.24em] text-copper">
        {content.anchors.eyebrow}
      </p>
      <div class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <h2 class="max-w-2xl text-3xl font-semibold tracking-[-0.03em] text-ink sm:text-4xl lg:text-5xl">
          {content.anchors.title}
        </h2>
        <p class="max-w-2xl text-base leading-7 text-smoke">
          {content.anchors.text}
        </p>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-2">
        {content.anchors.items.map((item) => (
          <article class="rounded-[1.5rem] border border-ink/10 bg-cream/40 p-5">
            <h3 class="text-lg font-semibold text-ink">{item.name}</h3>
            <p class="mt-3 text-sm leading-7 text-smoke">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-copper">
          {content.pairings.eyebrow}
        </p>
        <h2 class="mt-4 max-w-xl text-3xl font-semibold tracking-[-0.03em] text-ink sm:text-4xl lg:text-5xl">
          {content.pairings.title}
        </h2>
        <p class="mt-5 max-w-xl text-base leading-7 text-smoke">
          {content.pairings.text}
        </p>
      </div>

      <div class="rounded-[2rem] border border-ink/10 bg-ink p-6 text-white shadow-[0_24px_70px_-45px_rgba(29,29,27,0.6)] md:p-8">
        <div class="flex flex-wrap gap-3">
          {content.pairings.options.map((option) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/85">
              {option}
            </span>
          ))}
        </div>
        <p class="mt-6 text-sm leading-7 text-white/70">{content.pairings.note}</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[88rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-16">
    <div class="rounded-[2.25rem] bg-[linear-gradient(135deg,rgba(29,29,27,1),rgba(45,42,37,1))] p-7 text-white sm:p-8 md:p-10 lg:p-12">
      <p class="text-xs uppercase tracking-[0.24em] text-copper-soft">
        {content.cta.eyebrow}
      </p>
      <div class="mt-4 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <h2 class="max-w-2xl text-3xl font-semibold tracking-[-0.03em] sm:text-4xl lg:text-5xl">
          {content.cta.title}
        </h2>
        <p class="max-w-2xl text-base leading-7 text-white/75">
          {content.cta.text}
        </p>
      </div>
      <a
        href={getLocalizedPath(lang, "booking")}
        class="mt-8 inline-flex items-center rounded-full bg-copper px-6 py-3.5 text-sm font-medium text-white transition hover:opacity-90"
      >
        {content.cta.button}
      </a>
    </div>
  </section>
</main>
