---
import Layout from "../layouts/Layout.astro";
import { getLocalizedPath, languages, type Locale } from "../i18n/ui";
---

<Layout
  title="Pasta Lab & Smoked Flavors | Tallinn language gateway"
  description="Choose a language to enter Pasta Lab & Smoked Flavors."
  lang="en"
  canonicalUrl={getLocalizedPath("it")}
  noindex={true}
>
  <main class="mx-auto grid min-h-[calc(100vh-5rem)] max-w-6xl place-items-center px-6 py-20">
    <section class="w-full max-w-3xl rounded-[2rem] border border-ink/10 bg-white p-8 shadow-sm md:p-12">
      <p class="text-sm uppercase tracking-[0.22em] text-copper">
        Tallinn · Contemporary Pasta Bistro
      </p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-6xl">
        Pasta Lab & Smoked Flavors
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-smoke">
        Choose a language to enter the restaurant site.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        {
          (Object.entries(languages) as [Locale, string][]).map(([code, label]) => (
            <a
              href={getLocalizedPath(code)}
              class="rounded-full bg-copper px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
            >
              {label}
            </a>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
