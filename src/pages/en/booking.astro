---
import Layout from "../../layouts/Layout.astro";
import BookingPage from "../../components/BookingPage.astro";
import { bookingContent } from "../../data/booking";

const c = bookingContent.en;
---

<Layout
  title={c.pageTitle}
  description={c.seo.description}
  lang="en"
  path="booking"
>
  <BookingPage content={c} />
</Layout>
